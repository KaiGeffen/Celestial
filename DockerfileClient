FROM node:18

RUN mkdir -p /home/node/app/node_modules && chown -R node:node /home/node/app

WORKDIR /home/node/app

# Install dependencies first, so this layer is only rebuilt when the
# package files change, not on every code change
COPY --chown=node:node ./client/package.json ./client/package-lock.json ./client/
USER node
WORKDIR /home/node/app/client
RUN npm install

# robots.txt and sitemap.xml are served from the client root by prodServer
COPY --chown=node:node ./client /home/node/app/client
COPY --chown=node:node ./shared /home/node/app/shared
# The marketing sites (about/press/privacy/streamer) ship in their own image
# (see sites/Dockerfile), not here — the game image stays lean.

# Build in the image, not at container start: the asset cache-busting version
# is minted at build time, so building on start would bust every player's
# cache on every container restart, not just on real deploys
RUN npm run build:prod

EXPOSE 8083

CMD [ "node", "prodServer.cjs" ]