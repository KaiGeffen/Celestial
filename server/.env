DATABASE_URL=postgresql://postgres:postgres@localhost:5432/celestial_dev
STRIPE_SECRET_KEY=notasecretkey
STRIPE_WEBHOOK_SECRET=notasecretwebhookkey
# Secret used to sign reconnect session tokens. MUST be overridden in production
# with a long random value — anyone who knows it can forge any account's session.
SESSION_SECRET=dev-only-session-secret-change-in-prod
