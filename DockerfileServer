FROM node:18

RUN mkdir -p /home/node/app/node_modules && chown -R node:node /home/node/app

WORKDIR /home/node/app

# Install dependencies first, so this layer is only rebuilt when the
# package files change, not on every code change
COPY --chown=node:node ./server/package.json ./server/package-lock.json ./server/
USER node
WORKDIR /home/node/app/server
RUN npm install

# Copy server source + shared (imported via ../../shared, bundled by webpack)
COPY --chown=node:node ./server /home/node/app/server
COPY --chown=node:node ./shared /home/node/app/shared

# Build in the image (webpack bundles src + shared into dist/index.js)
RUN npm run build

CMD [ "npm", "run", "start" ]
