{
  "compilerOptions": {
    "target": "es5",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strictPropertyInitialization": false,
    "strictNullChecks": false,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*",
    "node_modules/phaser3-rex-plugins-types",
    "../shared/animation.ts",
    "../shared/state/keyword.ts",
    "../shared/data/avatarNames.ts"
  ]
}
