{
  "name": "celestial",
  "version": "1.0.0",
  "description": "Celestial - Digital Card Game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "node run-electron-builder.js --win --mac --linux",
    "dist:win": "node run-electron-builder.js --win",
    "dist:mac": "node run-electron-builder.js --mac",
    "dist:linux": "node run-electron-builder.js --linux"
  },
  "build": {
    "appId": "gg.celestialdecks.celestial",
    "productName": "Celestial",
    "icon": "icon.png",
    "files": [
      "main.js",
      "preload.js",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../client",
        "to": "client",
        "filter": [
          "index.html",
          "style.css",
          "dist/**",
          "assets/**"
        ]
      }
    ],
    "directories": {
      "output": "../electron-dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "steamworks.js": "^0.4.0"
  }
}
